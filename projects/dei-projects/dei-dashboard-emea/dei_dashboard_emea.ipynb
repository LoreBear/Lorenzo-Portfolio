 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# EMEA DEI Dashboard Analysis\n",
    "\n",
    "**Note**: All data presented in this analysis is synthetic and generated for demonstration purposes only.\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "\n",
    "# Set style for professional plots\n",
    "plt.style.use('seaborn-v0_8')\n",
    "sns.set_palette(\"husl\")\n",
    "\n",
    "# Set random seed for reproducibility\n",
    "np.random.seed(42)\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Data Generation\n",
    "\n",
    "Generating synthetic EMEA DEI data for analysis."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Define EMEA regions\n",
    "regions = ['UK', 'Germany', 'France', 'Netherlands', 'Spain', 'Italy', 'Sweden', 'Poland', 'UAE', 'South Africa']\n",
    "\n",
    "# Define demographic groups\n",
    "genders = ['Male', 'Female', 'Non-binary']\n",
    "ethnicities = ['White European', 'Black African', 'South Asian', 'East Asian', 'Middle Eastern', 'Mixed/Other']\n",
    "age_groups = ['Under 30', '30-45', '46-60', 'Over 60']\n",
    "disability_status = ['No disability', 'Has disability']\n",
    "lgbtq_status = ['Not LGBTQ+', 'LGBTQ+']\n",
    "\n",
    "# Create employee dataset\n",
    "n_employees = 1000\n",
    "\n",
    "data = []\n",
    "for i in range(n_employees):\n",
    "    region = np.random.choice(regions, p=[0.15, 0.18, 0.15, 0.08, 0.12, 0.10, 0.07, 0.05, 0.05, 0.05])\n",
    "    gender = np.random.choice(genders, p=[0.48, 0.48, 0.04])\n",
    "    ethnicity = np.random.choice(ethnicities, p=[0.55, 0.08, 0.12, 0.08, 0.10, 0.07])\n",
    "    age_group = np.random.choice(age_groups, p=[0.25, 0.35, 0.30, 0.10])\n",
    "    disability = np.random.choice(disability_status, p=[0.85, 0.15])\n",
    "    lgbtq = np.random.choice(lgbtq_status, p=[0.90, 0.10])\n",
    "    \n",
    "    # Hiring year (2020-2023)\n",
    "    hire_year = np.random.choice([2020, 2021, 2022, 2023], p=[0.20, 0.25, 0.30, 0.25])\n",
    "    \n",
    "    # Performance rating (1-5 scale)\n",
    "    performance = np.random.normal(3.5, 0.8)\n",
    "    performance = np.clip(performance, 1, 5)\n",
    "    \n",
    "    # Salary (base + variations based on factors)\n",
    "    base_salary = 50000\n",
    "    # Region adjustment\n",
    "    region_adj = {'UK': 1.2, 'Germany': 1.15, 'France': 1.1, 'Netherlands': 1.1, \n",
    "                  'Spain': 0.9, 'Italy': 0.85, 'Sweden': 1.1, 'Poland': 0.7, \n",
    "                  'UAE': 1.0, 'South Africa': 0.6}\n",
    "    salary = base_salary * region_adj[region]\n",
    "    # Gender pay gap (simulated)\n",
    "    if gender == 'Female':\n",
    "        salary *= 0.92\n",
    "    elif gender == 'Non-binary':\n",
    "        salary *= 0.90\n",
    "    # Ethnicity adjustment\n",
    "    ethnicity_adj = {'White European': 1.0, 'Black African': 0.88, 'South Asian': 0.92, \n",
    "                     'East Asian': 0.95, 'Middle Eastern': 0.90, 'Mixed/Other': 0.93}\n",
    "    salary *= ethnicity_adj[ethnicity]\n",
    "    # Add some random variation\n",
    "    salary *= np.random.normal(1.0, 0.1)\n",
    "    salary = max(30000, salary)\n",
    "    \n",
    "    # Attrition flag (higher for underrepresented groups)\n",
    "    attrition_risk = 0.1\n",
    "    if gender == 'Female':\n",
    "        attrition_risk += 0.05\n",
    "    if ethnicity in ['Black African', 'South Asian']:\n",
    "        attrition_risk += 0.08\n",
    "    if disability == 'Has disability':\n",
    "        attrition_risk += 0.07\n",
    "    if lgbtq == 'LGBTQ+':\n",
    "        attrition_risk += 0.04\n",
    "    attrition = np.random.random() < attrition_risk\n",
    "    \n",
    "    data.append({\n",
    "        'employee_id': f'EMP{i:04d}',\n",
    "        'region': region,\n",
    "        'gender': gender,\n",
    "        'ethnicity': ethnicity,\n",
    "        'age_group': age_group,\n",
    "        'disability_status': disability,\n",
    "        'lgbtq_status': lgbtq,\n",
    "        'hire_year': hire_year,\n",
    "        'performance_rating': round(performance, 2),\n",
    "        'salary': round(salary, 2),\n",
    "        'attrition': attrition\n",
    "    })\n",
    "\n",
    "df = pd.DataFrame(data)\n",
    "print(f\"Generated dataset with {len(df)} employees\")\n",
    "print(df.head())\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Hiring Diversity by Gender/Region\n",
    "\n",
    "Analyzing hiring diversity across gender and regional dimensions."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Hiring diversity by gender and region\n",
    "gender_region = pd.crosstab(df['region'], df['gender'], normalize='index') * 100\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(12, 8))\n",
    "gender_region.plot(kind='bar', stacked=True, ax=ax)\n",
    "plt.title('Gender Distribution by Region (%)', fontsize=16, fontweight='bold', pad=20)\n",
    "plt.xlabel('Region', fontsize=12)\n",
    "plt.ylabel('Percentage (%)', fontsize=12)\n",
    "plt.legend(title='Gender', bbox_to_anchor=(1.05, 1), loc='upper left')\n",
    "plt.xticks(rotation=45)\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# Print summary statistics\n",
    print(\"Gender Diversity by Region:\")\n",
    print(gender_region.round(1))\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Attrition by Demographic Group\n",
    "\n",
    "Examining attrition rates across different demographic groups."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Attrition analysis by demographic groups\n",
    "attrition_by_gender = df.groupby('gender')['attrition'].mean() * 100\n",
    "attrition_by_ethnicity = df.groupby('ethnicity')['attrition'].mean() * 100\n",
    "attrition_by_disability = df.groupby('disability_status')['attrition'].mean() * 100\n",
    "attrition_by_lgbtq = df.groupby('lgbtq_status')['attrition'].mean() * 100\n",
    "\n",
    "fig, axes = plt.subplots(2, 2, figsize=(15, 12))\n",
    "\n",
    # Gender attrition\n",
    "axes[0,0].bar(attrition_by_gender.index, attrition_by_gender.values, color=['#1f77b4', '#ff7f0e', '#2ca02c'])\n",
    "axes[0,0].set_title('Attrition Rate by Gender (%)', fontweight='bold')\n",
    "axes[0,0].set_ylabel('Attrition Rate (%)')\n",
    "for i, v in enumerate(attrition_by_gender.values):\n",
    "    axes[0,0].text(i, v + 0.5, f'{v:.1f}%', ha='center', fontweight='bold')\n",
    "\n",
    # Ethnicity attrition\n",
    "axes[0,1].bar(range(len(attrition_by_ethnicity)), attrition_by_ethnicity.values, color=plt.cm.Set3(np.linspace(0, 1, len(attrition_by_ethnicity))))\n",
    "axes[0,1].set_title('Attrition Rate by Ethnicity (%)', fontweight='bold')\n",
    "axes[0,1].set_ylabel('Attrition Rate (%)')\n",
    "axes[0,1].set_xticks(range(len(attrition_by_ethnicity)))\n",
    "axes[0,1].set_xticklabels(attrition_by_ethnicity.index, rotation=45, ha='right')\n",
    "for i, v in enumerate(attrition_by_ethnicity.values):\n",
    "    axes[0,1].text(i, v + 0.5, f'{v:.1f}%', ha='center', fontweight='bold')\n",
    "\n",
    # Disability attrition\n",
    "axes[1,0].bar(attrition_by_disability.index, attrition_by_disability.values, color=['#1f77b4', '#d62728'])\n",
    "axes[1,0].set_title('Attrition Rate by Disability Status (%)', fontweight='bold')\n",
    "axes[1,0].set_ylabel('Attrition Rate (%)')\n",
    "for i, v in enumerate(attrition_by_disability.values):\n",
    "    axes[1,0].text(i, v + 0.5, f'{v:.1f}%', ha='center', fontweight='bold')\n",
    "\n",
    # LGBTQ+ attrition\n",
    "axes[1,1].bar(attrition_by_lgbtq.index, attrition_by_lgbtq.values, color=['#1f77b4', '#d62728'])\n",
    "axes[1,1].set_title('Attrition Rate by LGBTQ+ Status (%)', fontweight='bold')\n",
    "axes[1,1].set_ylabel('Attrition Rate (%)')\n",
    "for i, v in enumerate(attrition_by_lgbtq.values):\n",
    "    axes[1,1].text(i, v + 0.5, f'{v:.1f}%', ha='center', fontweight='bold')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "print(\"Attrition Rates by Demographic Group:\")\n",
    print(\"\\nGender:\")\n",
    print(attrition_by_gender.round(2))\n",
    print(\"\\nEthnicity:\")\n",
    print(attrition_by_ethnicity.round(2))\n",
    print(\"\\nDisability Status:\")\n",
    print(attrition_by_disability.round(2))\n",
    print(\"\\nLGBTQ+ Status:\")\n",
    print(attrition_by_lgbtq.round(2))\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Representation Trends Over 3 Years\n",
    "\n",
    "Tracking representation trends from 2020 to 2023 hiring cohorts."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    # Calculate yearly hiring trends for underrepresented groups\n",
    "df['hire_year'] = df['hire_year'].astype(int)\n",
    "\n",
    # Define underrepresented groups\n",
    "df['is_female'] = (df['gender'] == 'Female').astype(int)\n",
    "df['is_ethnic_minority'] = (~df['ethnicity'].isin(['White European'])).astype(int)\n",
    "df['has_disability'] = (df['disability_status'] == 'Has disability').astype(int)\n",
    "df['is_lgbtq'] = (df['lgbtq_status'] == 'LGBTQ+').astype(int)\n",
    "\n",
    # Group by hire year and calculate representation percentages\n",
    "yearly_trends = df.groupby('hire_year').agg({\n",
    "    'is_female': 'mean',\n",
    "    'is_ethnic_minority': 'mean',\n",
    "    'has_disability': 'mean',\n",
    "    'is_lgbtq': 'mean'\n",
    "}) * 100\n",
    "\n",
    "yearly_trends = yearly_trends.round(2)\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(12, 8))\n",
    "yearly_trends.plot(kind='line', marker='o', linewidth=2, markersize=8, ax=ax)\n",
    "plt.title('Representation Trends Over Time (2020-2023)', fontsize=16, fontweight='bold', pad=20)\n",
    "plt.xlabel('Hire Year', fontsize=12)\n",
    "plt.ylabel('Representation (%)', fontsize=12)\n",
    "plt.legend(title='Demographic Group', labels=['Female', 'Ethnic Minority', 'Has Disability', 'LGBTQ+'], bbox_to_anchor=(1.05, 1), loc='upper left')\n",
    "plt.grid(True, alpha=0.3)\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "print(\"Yearly Representation Trends:\")\n",
    print(yearly_trends)\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Key Findings Summary\n",
    "\n",
    "Summary of key insights from the EMEA DEI analysis."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Key findings calculation\n",
    "total_employees = len(df)\n",
    "female_pct = (df['gender'] == 'Female').mean() * 100\n",
    "ethnic_minority_pct = (~df['ethnicity'].isin(['White European'])).mean() * 100\n",
    "disability_pct = (df['disability_status'] == 'Has disability').mean() * 100\n",
    "lgbtq_pct = (df['lgbtq_status'] == 'LGBTQ+').mean() * 100\n",
    "\n",
    "overall_attrition = df['attrition'].mean() * 100\n",
    "female_attrition = df[df['gender'] == 'Female']['attrition'].mean() * 100\n",
    "male_attrition = df[df['gender'] == 'Male']['attrition'].mean() * 100\n",
    "\n",
    "gender_pay_gap = df[df['gender'] == 'Male']['salary'].mean() - df[df['gender'] == 'Female']['salary'].mean()\n",
    "gender_pay_gap_pct = (gender_pay_gap / df[df['gender'] == 'Male']['salary'].mean()) * 100\n",
    "\n",
    "print(\"KEY FINDINGS SUMMARY\")\n",
    print(\"=\" * 50)\n",
    print(f\"Total Employees Analyzed: {total_employees}\")\n",
    print(f\"\\nRepresentation Metrics:\")\n",
    print(f\"  - Female Representation: {female_pct:.1f}%\")\n",
    print(f\"  - Ethnic Minority Representation: {ethnic_minority_pct:.1f}%\")\n",
    print(f\"  - Employees with Disability: {disability_pct:.1f}%\")\n",
    print(f\"  - LGBTQ+ Representation: {lgbtq_pct:.1f}%\")\n",
    print(f\"\\nAttrition Analysis:\")\n",
    print(f\"  - Overall Attrition Rate: {overall_attrition:.1f}%\")\n",
    print(f\"  - Female Attrition Rate: {female_attrition:.1f}%\")\n",
    print(f\"  - Male Attrition Rate: {male_attrition:.1f}%\")\n",
    print(f\"  - Attrition Ratio (Female/Male): {female_attrition/male_attrition:.2f}\")\n",
    print(f\"\\nCompensation Equity:\")\n",
    print(f\"  - Gender Pay Gap: {gender_pay_gap:.0f} currency units\")\n",
    print(f\"  - Gender Pay Gap Percentage: {gender_pay_gap_pct:.1f}%\")\n",
    print(f\"\\nTrend Insights:\")\n",
    print(f\"  - Female representation shows {'improving' if yearly_trends.loc[2023, 'is_female'] > yearly_trends.loc[2020, 'is_female'] else 'declining'} trend (2020: {yearly_trends.loc[2020, 'is_female']:.1f}% → 2023: {yearly_trends.loc[2023, 'is_female']:.1f}%\")\n",
    print(f\"  - Ethnic minority representation shows {'improving' if yearly_trends.loc[2023, 'is_ethnic_minority'] > yearly_trends.loc[2020, 'is_ethnic_minority'] else 'declining'} trend (2020: {yearly_trends.loc[2020, 'is_ethnic_minority']:.1f}% → 2023: {yearly_trends.loc[2023, 'is_ethnic_minority']:.1f}%\")\n"
   ]
  }
 ],
