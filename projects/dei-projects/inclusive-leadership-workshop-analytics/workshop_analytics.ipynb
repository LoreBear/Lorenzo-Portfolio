{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Inclusive Leadership Workshop Analytics\n",
    "\n",
    "**Note**: All survey data presented in this analysis is synthetic and generated for demonstration purposes only.\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "from scipy import stats\n",
    "\n",
    "# Set style for professional plots\n",
    "plt.style.use('seaborn-v0_8')\n",
    "sns.set_palette(\"husl\")\n",
    "\n",
    "# Set random seed for reproducibility\n",
    "np.random.seed(42)\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Survey Design\n",
    "\n",
    "This section outlines the inclusive leadership competency framework used to assess workshop effectiveness."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Define inclusive leadership dimensions based on validated frameworks\n",
    "dimensions = [\n",
    "    'Self-Awareness & Bias Recognition',\n",
    "    'Empathetic Listening & Communication',\n",
    "    'Inclusive Decision-Making',\n",
    "    'Psychological Safety Creation',\n",
    "    'Advocacy for Underrepresented Groups',\n",
    "    'Cultural Intelligence & Global Mindset'\n",
    "]\n",
    "\n",
    # Define Likert scale options\n",
    "likert_scale = {\n",
    "    1: 'Strongly Disagree',\n",
    "    2: 'Disagree',\n",
    "    3: 'Neutral',\n",
    "    4: 'Agree',\n",
    "    5: 'Strongly Agree'\n",
    "}\n",
    "\n",
    print(\"Inclusive Leadership Dimensions Assessed:\")\n",
    for i, dim in enumerate(dimensions, 1):\n",
    print(f\"  {i}. {dim}\")\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Data Generation\n",
    "\n",
    "Generating synthetic pre/post workshop survey data for 50 participants."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    # Generate synthetic survey data\n",
    "n_participants = 50\n",
    "\n",
    # Create participant IDs\n",
    "participant_ids = [f'P{i:03d}' for i in range(1, n_participants + 1)]\n",
    "\n",
    # Generate pre-workshop scores (baseline)\n",
    "np.random.seed(42)\n",
    "pre_scores = {}\n",
    "for dim in dimensions:\n",
    "    # Baseline scores typically around 2.5-3.0 (between neutral and agree)\n",
    "    base_mean = np.random.uniform(2.5, 3.0)\n",
    "    pre_scores[dim] = np.clip(np.random.normal(base_mean, 0.8, n_participants), 1, 5)\n",
    "\n",
    # Generate post-workshop scores (expected improvement)\n",
    "np.random.seed(43)\n",
    "post_scores = {}\n",
    "for dim in dimensions:\n",
    "    # Expected improvement of 0.8-1.5 points after workshop\n",
    "    improvement = np.random.uniform(0.8, 1.5)\n",
    "    post_mean = np.mean(pre_scores[dim]) + improvement\n",
    "    post_scores[dim] = np.clip(np.random.normal(post_mean, 0.7, n_participants), 1, 5)\n",
    "\n",
    # Create DataFrames\n",
    "pre_df = pd.DataFrame(pre_scores, index=participant_ids)\n",
    "post_df = pd.DataFrame(post_scores, index=participant_ids)\n",
    "\n",
    # Add participant demographics (for potential subgroup analysis)\n",
    "np.random.seed(44)\n",
    "genders = np.random.choice(['Male', 'Female', 'Non-binary'], n_participants, p=[0.45, 0.50, 0.05])\n",
    "levels = np.random.choice(['Individual Contributor', 'Manager', 'Director', 'VP'], n_participants, p=[0.4, 0.35, 0.2, 0.05])\n",
    "departments = np.random.choice(['Engineering', 'Marketing', 'Sales', 'HR', 'Finance', 'Operations'], n_participants)\n",
    "\n",
    "pre_df['Gender'] = genders\n",
    "pre_df['Level'] = levels\n",
    "pre_df['Department'] = departments\n",
    "post_df['Gender'] = genders\n",
    "post_df['Level'] = levels\n",
    "post_df['Department'] = departments\n",
    "\n",
    print(f\"Generated survey data for {n_participants} participants\")\n",
    print(\"\\nPre-workshop scores (first 5 participants):\")\n",
    print(pre_df.head())\n",
    print(\"\\nPost-workshop scores (first 5 participants):\")\n",
    print(post_df.head())\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Pre vs Post Scores by Dimension\n",
    "\n",
    "Comparing average scores across all inclusive leadership dimensions before and after the workshop."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    # Calculate mean scores and improvements\n",
    "pre_means = pre_df[dimensions].mean()\n",
    "post_means = post_df[dimensions].mean()\n",
    "improvements = post_means - pre_means\n",
    "\n",
    "results_df = pd.DataFrame({\n",
    "    'Pre_Workshop': pre_means,\n",
    "    'Post_Workshop': post_means,\n",
    "    'Improvement': improvements,\n",
    "    'Percent_Change': (improvements / pre_means) * 100\n",
    "})\n",
    "\n",
    print(\"Inclusive Leadership Workshop Results:\")\n",
    print(\"=\" * 60)\n",
    print(results_df.round(2))\n",
    "\n",
    # Create comparison bar chart\n",
    "fig, ax = plt.subplots(figsize=(12, 8))\n",
    "\n",
    "x = np.arange(len(dimensions))\n",
    "width = 0.35\n",
    "\n",
    "bars1 = ax.bar(x - width/2, pre_means, width, label='Pre-Workshop', color='#1f77b4', alpha=0.8)\n",
    "bars2 = ax.bar(x + width/2, post_means, width, label='Post-Workshop', color='#ff7f0e', alpha=0.8)\n",
    "\n",
    "ax.set_xlabel('Inclusive Leadership Dimensions', fontsize=12, fontweight='bold')\n",
    "ax.set_ylabel('Average Score (1-5 Scale)', fontsize=12, fontweight='bold')\n",
    "ax.set_title('Pre vs Post Workshop Scores by Dimension', fontsize=16, fontweight='bold', pad=20)\n",
    "ax.set_xticks(x)\n",
    "ax.set_xticklabels(dimensions, rotation=15, ha='right')\n",
    "ax.legend()\n",
    "ax.set_ylim(0, 5.5)\n",
    "\n",
    # Add value labels on bars\n",
    "def autolabel(bars):\n",
    \"\"\"Attach a text label above each bar displaying its height\"\"\"\n",
    "    for bar in bars:\n",
    "        height = bar.get_height()\n",
    "        ax.annotate(f'{height:.2f}',\n",
    "                    xy=(bar.get_x() + bar.get_width() / 2, height),\n",
    "                    xytext=(0, 3),  # 3 points vertical offset\n",
    "                    textcoords=\"offset points\",\n",
    "                    ha='center', va='bottom', fontweight='bold', fontsize=9)\n",
    "\n",
    "autolabel(bars1)\n",
    "autolabel(bars2)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    # Statistical significance testing\n",
    print(\"\\nStatistical Significance of Improvements:\")\n",
    print(\"-\" * 50)\n",
    "for dim in dimensions:\n",
    "    t_stat, p_val = stats.ttest_rel(pre_df[dim], post_df[dim])\n",
    "    print(f\"{dim}: t = {t_stat:.3f}, p = {p_val:.4f}\", end=\" \")\n",
    "    if p_val < 0.001:\n",
    "        print(\"***\")\n",
    "    elif p_val < 0.01:\n",
    "        print(\"**\")\n",
    "    elif p_val < 0.05:\n",
    "        print(\"*\")\n",
    "    else:\n",
    "        print(\"ns\")\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Statistical Delta\n",
    "\n",
    "Quantifying the statistical significance and effect size of workshop impact."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    # Calculate effect sizes (Cohen's d) for each dimension\n",
    "from scipy.stats import ttest_rel\n",
    "\n",
    "effect_sizes = {}\n",
    "for dim in dimensions:\n",
    "    # Cohen's d for paired samples\n",
    "    diff = post_df[dim] - pre_df[dim]\n",
    "    d = np.mean(diff) / np.std(diff, ddof=1)\n",
    "    effect_sizes[dim] = d\n",
    "\n",
    # Create summary statistics dataframe\n",
    "stats_summary = pd.DataFrame({\n",
    "    'Mean_Pre': pre_means,\n",
    "    'Mean_Post': post_means,\n",
    "    'Mean_Diff': improvements,\n",
    "    'Std_Diff': [np.std(post_df[dim] - pre_df[dim], ddof=1) for dim in dimensions],\n",
    "    'Cohen_D': [effect_sizes[dim] for dim in dimensions],\n",
    "    'p_Value': [stats.ttest_rel(pre_df[dim], post_df[dim])[1] for dim in dimensions],\n",
    "    'Significant': [stats.ttest_rel(pre_df[dim], post_df[dim])[1] < 0.05 for dim in dimensions]\n",
    "})\n",
    "\n",
    print(\"Statistical Summary of Workshop Impact:\")\n",
    print(\"=\" * 60)\n",
    print(stats_summary.round(3))\n",
    "\n",
    # Overall workshop effectiveness\n",
    "overall_improvement = np.mean(improvements)\n",
    "overall_effect_size = np.mean(list(effect_sizes.values()))\n",
    "\n",
    print(f\"\\nOverall Workshop Effectiveness:\")\n",
    print(f\"  Average Improvement Across All Dimensions: {overall_improvement:.2f} points\")\n",
    print(f\"  Overall Effect Size (Cohen's d): {overall_effect_size:.2f}\")\n",
    print(f\"  Percentage Improvement: {(overall_improvement / np.mean(pre_means)) * 100:.1f}%\")\n",
    "\n",
    # Interpret effect size\n",
    "if overall_effect_size < 0.2:\n",
    "    interpretation = \"Small effect\"\n",
    "elif overall_effect_size < 0.5:\n",
    "    interpretation = \"Medium effect\"\n",
    "elif overall_effect_size < 0.8:\n",
    "    interpretation = \"Large effect\"\n",
    "else:\n",
    "    interpretation = \"Very large effect\"\n",
    "\n",
    print(f\"  Effect Size Interpretation: {interpretation}\")\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Visualisations\n",
    "\n",
    "Additional visualizations to illustrate workshop impact and participant demographics."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "fig, axes = plt.subplots(2, 2, figsize=(15, 12))\n",
    "\n",
    # Plot 1: Improvement distribution by dimension\n",
    "improvement_data = []\n",
    "for dim in dimensions:\n",
    "    improvement_data.extend([(dim, score) for score in (post_df[dim] - pre_df[dim])])\n",
    "\n",
    "improvement_df = pd.DataFrame(improvement_data, columns=['Dimension', 'Improvement'])\n",
    "\n",
    "sns.boxplot(data=improvement_df, x='Dimension', y='Improvement', ax=axes[0,0])\n",
    "axes[0,0].set_title('Distribution of Score Improvements by Dimension', fontweight='bold')\n",
    "axes[0,0].set_ylabel('Improvement (Post - Pre)')\n",
    "axes[0,0].tick_params(axis='x', rotation=45)\n",
    "axes[0,0].axhline(y=0, color='red', linestyle='--', alpha=0.7, label='No Change')\n",
    "axes[0,0].legend()\n",
    "\n",
    # Plot 2: Participant demographics\n",
    "gender_counts = pre_df['Gender'].value_counts()\n",
    "axes[0,1].pie(gender_counts.values, labels=gender_counts.index, autopct='%1.1f%%', startangle=90)\n",
    "axes[0,1].set_title('Participant Gender Distribution', fontweight='bold')\n",
    "\n",
    # Plot 3: Improvement by participant level\n",
    "level_improvement = []\n",
    "for _, row in pre_df.iterrows():\n",
    "    level = row['Level']\n",
    "    avg_improvement = np.mean([post_df.loc[row.name, dim] - pre_df.loc[row.name, dim] for dim in dimensions])\n",
    "    level_improvement.append((level, avg_improvement))\n",
    "\n",
    "level_df = pd.DataFrame(level_improvement, columns=['Level', 'Avg_Improvement'])\n",
    "level_order = ['Individual Contributor', 'Manager', 'Director', 'VP']\n",
    "level_df['Level'] = pd.Categorical(level_df['Level'], categories=level_order, ordered=True)\n",
    "level_df = level_df.sort_values('Level')\n",
    "\n",
    "sns.barplot(data=level_df, x='Level', y='Avg_Improvement', ax=axes[1,0])\n",
    "axes[1,0].set_title('Average Improvement by Participant Level', fontweight='bold')\n",
    "axes[1,0].set_ylabel('Average Improvement (Points)')\n",
    "axes[1,0].tick_params(axis='x', rotation=45)\n",
    "\n",
    # Plot 4: Radar chart for dimensions\n",
    "from math import pi\n",
    "\n",
    # Number of variables\n",
    "categories = list(dimensions)\n",
    "N = len(categories)\n",
    "\n",
    # What will be the angle of each axis in the plot (divide the plot / number of variables)\n",
    "angles = [n / float(N) * 2 * pi for n in range(N)]\n",
    "angles += angles[:1]\n",
    "\n",
    # Initialize the spider plot\n",
    "ax = plt.subplot(2, 2, 4, projection='polar')\n",
    "\n",
    # Pre-workshop values\n",
    "pre_values = pre_means.values.flatten().tolist()\n",
    "pre_values += pre_values[:1]\n",
    "ax.plot(angles, pre_values, 'o-', linewidth=2, label='Pre-Workshop', color='#1f77b4')\n",
    "ax.fill(angles, pre_values, alpha=0.25, color='#1f77b4')\n",
    "\n",
    # Post-workshop values\n",
    "post_values = post_means.values.flatten().tolist()\n",
    "post_values += post_values[:1]\n",
    "ax.plot(angles, post_values, 'o-', linewidth=2, label='Post-Workshop', color='#ff7f0e')\n",
    "ax.fill(angles, post_values, alpha=0.25, color='#ff7f0e')\n",
    "\n",
    "ax.set_thetagrids(np.degrees(angles[:-1]), categories)\n",
    "ax.set_ylim(0, 5)\n",
    "ax.set_title('Inclusive Leadership Profile: Pre vs Post Workshop', fontweight='bold', pad=20)\n",
    "ax.legend(loc='upper right', bbox_to_anchor=(1.3, 1.1))\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n"
   ]
  }
 ],
